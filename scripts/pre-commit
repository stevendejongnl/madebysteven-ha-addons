#!/usr/bin/env bash
# Pre-commit: lint + typecheck + unit tests (all parallel).
set -euo pipefail

# shellcheck source=scripts/shared.sh
source "$(dirname "$0")/shared.sh"

echo "🔍 Pre-commit checks..."

# ── Rebase check ───────────────────────────────────────────────────────────────
# Fetch remote and warn if behind — can't auto-rebase here because staged
# changes are present. The pre-push hook will auto-rebase before pushing.
BRANCH=$(git rev-parse --abbrev-ref HEAD)
REMOTE=$(git config "branch.${BRANCH}.remote" 2>/dev/null || echo "origin")
REMOTE_BRANCH="${REMOTE}/${BRANCH}"

git fetch "$REMOTE" "$BRANCH" --quiet 2>/dev/null || true

if git rev-parse --verify "$REMOTE_BRANCH" >/dev/null 2>&1; then
  BEHIND=$(git rev-list --count "HEAD..${REMOTE_BRANCH}")
  if [ "$BEHIND" -gt 0 ]; then
    echo "⚠  Branch is $BEHIND commit(s) behind ${REMOTE_BRANCH} — pre-push will rebase automatically."
  fi
fi

_be_lint()    { cd "$ROOT/picnic/backend";  uv run ruff check .; }
_be_mypy()    { cd "$ROOT/picnic/backend";  uv run mypy src; }
_be_tests()   { cd "$ROOT/picnic/backend";  uv run pytest -q --tb=short; }
_fe_types()   { cd "$ROOT/picnic/frontend"; npm run typecheck --silent; }
_fe_lint()    { cd "$ROOT/picnic/frontend"; npm run lint --silent; }
_fe_unit()    { cd "$ROOT/picnic/frontend"; npm test --silent; }
_shellcheck() { shellcheck -x "$ROOT/scripts/shared.sh" "$ROOT/scripts/pre-commit" \
                  "$ROOT/scripts/pre-push" "$ROOT/scripts/install-hooks.sh" \
                  "$ROOT/picnic/run.sh"; }
_hadolint()   { docker run --rm \
                  --entrypoint /bin/hadolint \
                  -v "$ROOT/.hadolint.yaml:/.hadolint.yaml:ro" \
                  -v "$ROOT/picnic/Dockerfile:/Dockerfile:ro" \
                  hadolint/hadolint \
                  --config /.hadolint.yaml /Dockerfile; }

run_parallel "Commit blocked" \
  "backend:lint"   _be_lint    \
  "backend:mypy"   _be_mypy    \
  "backend:tests"  _be_tests   \
  "frontend:types" _fe_types   \
  "frontend:lint"  _fe_lint    \
  "frontend:unit"  _fe_unit    \
  "shellcheck"     _shellcheck \
  "hadolint"       _hadolint

echo "✅ All checks passed — committing."
